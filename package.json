{
	"name": "vagus",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*"
	],
	"scripts": {
		"dev:foreground": "scripts/dev-server.sh start --foreground",
		"dev:agent": "scripts/dev-server.sh start",
		"dev:status": "scripts/dev-server.sh status",
		"dev:stop": "scripts/dev-server.sh stop",
		"port": "bun run scripts/port-allocator.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit -p apps/server/tsconfig.json && tsc --noEmit -p apps/web/tsconfig.json"
	},
	"devDependencies": {
		"bun-plugin-tailwind": "^0.1.2",
		"typescript": "^7.0.2"
	}
}
