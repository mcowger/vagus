{
	"worktree": {
		"setup": [
			"bun install",
			"cp \"$PASEO_SOURCE_CHECKOUT_PATH/.env\" \"$PWD/.env\""
		],
		"servicePorts": {
			"portScript": "./scripts/paseo-port.ts"
		}
	},
	"scripts": {
		"web": {
			"type": "service",
			"command": "DEV_AUTH_ENABLED=true bun run dev:foreground"
		},
		"seed-dev": {
			"command": "DEV_AUTH_ENABLED=true bun scripts/seed-dev.ts"
		},
		"test": {
			"command": "bun test"
		},
		"deploy-staging": {
			"command": "bun run deploy:staging"
		}
	}
}
