{
	"worktree": {
		"setup": [
			"bun install",
			"cp \"$PASEO_SOURCE_CHECKOUT_PATH/.env\" \"$PWD/.env\""
		],
		"servicePorts": {
			"portScript": "./scripts/paseo-port.ts"
		}
	},
	"scripts": {
		"web": {
			"type": "service",
			"command": "bun run dev:foreground"
		},
		"test": {
			"command": "bun test"
		},
		"deploy-staging": {
			"command": "bun run deploy:staging"
		}
	}
}
